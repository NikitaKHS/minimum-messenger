# App
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-secret-key

# Database
DATABASE_URL=postgresql+asyncpg://minimum:minimum_secret@postgres:5432/minimum

# Redis
REDIS_URL=redis://:redis_secret@redis:6379/0

# S3 / MinIO
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_BUCKET_NAME=minimum-attachments
S3_REGION=us-east-1

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — comma separated
CORS_ORIGINS=http://localhost:3000

# Admin
ADMIN_SECRET_KEY=change-me-admin-secret

# Postgres (used by docker-compose)
POSTGRES_DB=minimum
POSTGRES_USER=minimum
POSTGRES_PASSWORD=minimum_secret

# Redis (used by docker-compose)
REDIS_PASSWORD=redis_secret

# MinIO (used by docker-compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=minimum-attachments
