{
  "uid": "minimum-overview",
  "title": "Minimum — Overview",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total{job=\"minimum_backend\"}[1m])",
          "legendFormat": "{{method}} {{handler}} {{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (5xx/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total{job=\"minimum_backend\",status_code=~\"5..\"}[1m])",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Latency p99 (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"minimum_backend\"}[5m]))",
          "legendFormat": "p99 {{handler}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "minimum_ws_active_connections",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "id": 5,
      "title": "Auth Events",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(minimum_auth_attempts_total[5m])",
          "legendFormat": "{{event}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Messages Sent",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(minimum_messages_sent_total[1m])",
          "legendFormat": "{{chat_type}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Logs",
      "type": "logs",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "{container=~\".*backend.*\"}",
          "legendFormat": ""
        }
      ]
    }
  ]
}
